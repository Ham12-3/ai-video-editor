# =============================================================================
# ClipForge Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# Only DATABASE_URL, REDIS_URL, NEXTAUTH_SECRET, and NEXTAUTH_URL are required.
# =============================================================================

# Database (PostgreSQL)
# Local: use the Docker Compose defaults below
# Production: use your Neon connection string
DATABASE_URL="postgresql://user:password@localhost:5432/clipforge"

# Redis
# Local: use the Docker Compose defaults below
# Production: use your Upstash Redis URL
REDIS_URL="redis://localhost:6379"

# NextAuth.js
# NEXTAUTH_SECRET: generate with `openssl rand -base64 32` or `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`
NEXTAUTH_SECRET="generate-a-random-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (optional, leave empty to disable Google sign-in)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# API Key Encryption
# 64-character hex string (32 bytes) for AES-256-GCM encryption of OpenAI API keys.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# In development, a deterministic key is used if this is empty (NOT SECURE).
# In production, this MUST be set explicitly.
ENCRYPTION_KEY=""

# File Storage
# Directory for uploaded videos and rendered output.
# Default: ./uploads (relative to project root)
UPLOAD_DIR="./uploads"

# Maximum upload file size in bytes.
# Default: 524288000 (500MB)
MAX_UPLOAD_SIZE="524288000"

# AI Models
# Override the default models used for analysis and review.
# Default analysis model: gpt-4.1 (supports vision + structured output)
# Default review model: gpt-4.1-mini (cheaper, text-only review)
MODEL_ANALYSIS=""
MODEL_REVIEW=""

# Hybrid Transcription
# Set to "true" to use gpt-4o-mini-transcribe alongside whisper-1 for better
# text accuracy while keeping whisper's word-level timestamps.
# Doubles the transcription API cost but produces cleaner captions.
# Default: disabled (whisper-1 only)
ENABLE_HYBRID_TRANSCRIPTION=""
